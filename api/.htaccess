# Proteger archivos sensibles del API
<FilesMatch "\.(sql|md)$">
    Require all denied
</FilesMatch>

# Bloquear acceso directo a los archivos de configuración
<FilesMatch "^config(\.example)?\.php$">
    Require all denied
</FilesMatch>

# Asegurar que el header Authorization llegue a PHP (necesario para el login del panel)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
